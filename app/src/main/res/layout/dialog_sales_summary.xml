<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:background="#0D0F14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 헤더 (타이틀 + 나가기) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💰 매출 집계"
                android:textColor="#00ff88"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:letterSpacing="0.03"/>

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="나가기"
                android:textSize="14sp"
                android:background="@drawable/btn_back_bg"
                android:textColor="#000000"
                android:paddingHorizontal="16dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- 월 네비게이션 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnPrevMonth"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="◀"
                android:textSize="18sp"
                android:background="@drawable/btn_nav_bg"
                android:textColor="#C0C6D8"
                android:stateListAnimator="@null"/>

            <TextView
                android:id="@+id/tvCurrentMonth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2025년 1월"
                android:textColor="#F0F2F5"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.05"/>

            <Button
                android:id="@+id/btnNextMonth"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▶"
                android:textSize="18sp"
                android:background="@drawable/btn_nav_bg"
                android:textColor="#C0C6D8"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- 요일 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="10dp"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="일"
                android:textColor="#FF6B6B"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="월"
                android:textColor="#8B92A8"
                android:textSize="13sp"
                android:gravity="center"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="화"
                android:textColor="#8B92A8"
                android:textSize="13sp"
                android:gravity="center"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="수"
                android:textColor="#8B92A8"
                android:textSize="13sp"
                android:gravity="center"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="목"
                android:textColor="#8B92A8"
                android:textSize="13sp"
                android:gravity="center"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="금"
                android:textColor="#8B92A8"
                android:textSize="13sp"
                android:gravity="center"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="토"
                android:textColor="#54A0FF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1F2940"/>

        <!-- 달력 그리드 -->
        <GridLayout
            android:id="@+id/calendarGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="7"
            android:rowCount="6"
            android:paddingVertical="8dp"/>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1F2940"
            android:layout_marginVertical="8dp"/>

        <!-- 1. 선택된 날짜 표시 (연월일) -->
        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="오늘"
            android:textColor="#00ff88"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:letterSpacing="0.03"/>

        <!-- 2. 당일 매출 합계 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/summary_daily_bg"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="당일 매출 합계"
                android:textColor="#C0C6D8"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvDailyTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0원"
                android:textColor="#00ff88"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- 3. 월 매출 합계 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/summary_monthly_bg"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="월 매출 합계"
                android:textColor="#C0C6D8"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMonthlyTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0원"
                android:textColor="#A855F7"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- 4. 입금 내역 리스트 (기록) -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/deposit_list_bg"
            android:padding="10dp"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:id="@+id/depositListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </androidx.core.widget.NestedScrollView>


    </LinearLayout>
</ScrollView>
