<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main"
    tools:context=".MainActivity">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_above="@+id/adContainer"
    android:fillViewport="true"
    android:overScrollMode="never">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 서비스 상태 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="14dp"
            android:background="@drawable/card_bg_primary">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1번, 아래 버튼 누르기"
                android:textColor="#ff0000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="4dp"
                android:letterSpacing="0.02"/>

            <Button
                android:id="@+id/serviceToggleButton"
                android:layout_width="220dp"
                android:layout_height="48dp"
                android:text="1번 버튼"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/btn_primary_bg"
                app:backgroundTint="@null"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:stateListAnimator="@null"
                android:elevation="4dp"
                android:letterSpacing="0.05"/>

            <Button
                android:id="@+id/permissionButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="권한 설정"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:background="@drawable/btn_dark_bg"
                app:backgroundTint="@null"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 백그라운드 실행 설정 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="14dp"
            android:background="@drawable/card_bg_primary">

            <TextView
                android:id="@+id/backgroundText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2번, 아래 버튼 누르기"
                android:textColor="#ff0000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="4dp"
                android:letterSpacing="0.02"/>

            <Button
                android:id="@+id/backgroundToggleButton"
                android:layout_width="220dp"
                android:layout_height="48dp"
                android:text="2번 버튼"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/btn_primary_bg"
                app:backgroundTint="@null"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:stateListAnimator="@null"
                android:elevation="4dp"
                android:letterSpacing="0.05"/>

            <Button
                android:id="@+id/batteryOptimizationButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="⚡ 상시 가동 모드 설정"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/btn_dark_bg"
                app:backgroundTint="@null"
                android:layout_gravity="center"
                android:layout_marginTop="6dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 볼륨과 속도 설정 (가로 배치) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <!-- 볼륨 설정 -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/card_bg_settings">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="알림 볼륨"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/volumeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="#00ff88"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>

                <SeekBar
                    android:id="@+id/volumeSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="#00ff88"
                    android:progressBackgroundTint="#2A3050"
                    android:thumbTint="#00ff88"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 속도 설정 -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/card_bg_settings">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="음성 속도"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/speedText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1.0x"
                    android:textColor="#00ff88"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>

                <SeekBar
                    android:id="@+id/speedSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:max="30"
                    android:progress="10"
                    android:progressTint="#00ff88"
                    android:progressBackgroundTint="#2A3050"
                    android:thumbTint="#00ff88"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- 테스트 재생 -->
    <Button
        android:id="@+id/testButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="4dp"
        android:text="🔊 테스트 재생"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/btn_dark_bg"
        app:backgroundTint="@null"
        android:textColor="#FFFFFF"
        android:stateListAnimator="@null"
        android:letterSpacing="0.01"/>

    <!-- 매출 집계 버튼 -->
    <Button
        android:id="@+id/salesSummaryButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="💰 매출 집계"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/btn_sales_bg"
        app:backgroundTint="@null"
        android:textColor="#ffffff"
        android:layout_marginTop="8dp"
        android:stateListAnimator="@null"
        android:elevation="6dp"
        android:letterSpacing="0.03"/>

    <!-- 팝업 알림 토글 버튼 -->
    <Button
        android:id="@+id/popupToggleButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="팝업 알림 켜짐"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/btn_dark_bg"
        app:backgroundTint="@null"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp"
        android:stateListAnimator="@null"
        android:elevation="6dp"
        android:letterSpacing="0.03"/>

    <!-- 사용방법 + 문의 (가로 배치) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/helpButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="📖 사용방법"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/btn_dark_bg"
            app:backgroundTint="@null"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:letterSpacing="0.02"/>

        <Button
            android:id="@+id/supportButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="❓ 문의"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/btn_dark_bg"
            app:backgroundTint="@null"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:letterSpacing="0.02"/>
    </LinearLayout>

</LinearLayout>
</ScrollView>

<!-- 배너 광고 컨테이너 -->
<LinearLayout
    android:id="@+id/adContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentBottom="true"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/ad_container_bg"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"/>

</RelativeLayout>
